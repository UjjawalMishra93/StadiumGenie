# StadiumGenie — copy this to .env and fill in values
# NEVER commit .env to git

# Required
GEMINI_API_KEY=your_google_ai_studio_key_here

# Optional overrides
MODEL_NAME=gemini-2.0-flash
PORT=3001
FEED_REFRESH_INTERVAL_MS=8000
CACHE_TTL_MS=60000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=20
NODE_ENV=development
